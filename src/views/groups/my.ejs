<%
  const totalGroups = groups.length;
  const activeGroups = groups.filter((group) => group.is_active).length;
  const levelsCount = new Set(groups.map((group) => group.catechesis_level_name || 'Sin nivel')).size;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page my-groups-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-collection-fill"></i>
            Catequista
          </span>
          <h1 class="dashboard-title mb-3">Mis grupos asignados</h1>
          <p class="dashboard-subtitle mb-0">
            Vista propia para ${escapeHtml(user.name)}. Consultá tus grupos, nivel, parroquia y estado actual.
          </p>
        </header>

        <section class="admin-resource-summary my-groups-summary" aria-label="Resumen de mis grupos">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-collection-fill"></i>
            </span>
            <span class="admin-metric-card__label">Grupos asignados</span>
            <strong class="admin-metric-card__value">${totalGroups}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-check2-circle"></i>
            </span>
            <span class="admin-metric-card__label">Grupos activos</span>
            <strong class="admin-metric-card__value">${activeGroups}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-layers-fill"></i>
            </span>
            <span class="admin-metric-card__label">Niveles cubiertos</span>
            <strong class="admin-metric-card__value">${totalGroups ? levelsCount : 0}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <a class="btn admin-resource-primary-action" href="/groups/my/new">
            <i class="bi bi-plus-circle-fill"></i>
            Crear grupo
          </a>
        </div>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
          ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-exclamation-circle-fill text-danger fs-5"></i><span>${escapeHtml(error)}</span></div>` : ''}
        </div>

        <section class="admin-table-card my-groups-panel" aria-labelledby="my-groups-title">
          <div class="admin-table-card__header my-groups-panel__header">
            <div>
              <h2 id="my-groups-title">
                <i class="bi bi-grid-3x3-gap-fill"></i>
                Tus grupos
              </h2>
              <p>Estos son los espacios de catequesis asociados a tu usuario.</p>
            </div>
          </div>

          ${groups.length === 0 ? `
            <div class="admin-table-empty my-groups-empty">
              <i class="bi bi-folder-x"></i>
              <strong>Todavía no tenés grupos asignados.</strong>
              <span>Creá tu primer grupo para empezar a registrar catecúmenos.</span>
            </div>
          ` : `
            <div class="my-groups-grid">
              ${groups.map((group) => `
                <article class="admin-metric-card my-group-card">
                  <span class="my-group-card__status badge ${group.is_active ? 'text-bg-success' : 'text-bg-secondary'}">
                    <i class="bi bi-circle-fill my-group-card__status-dot"></i>
                    ${group.is_active ? 'Activo' : 'Inactivo'}
                  </span>

                  <div class="my-group-card__body">
                    <span class="admin-metric-card__icon my-group-card__icon" aria-hidden="true">
                      <i class="bi bi-people-fill"></i>
                    </span>
                    <h3>${escapeHtml(group.name)}</h3>
                    <p>${escapeHtml(group.catechesis_level_name)}</p>
                  </div>

                  <dl class="my-group-card__meta">
                    <div>
                      <dt>Parroquia</dt>
                      <dd>${escapeHtml(group.parish_name)}</dd>
                    </div>
                    <div>
                      <dt>Año</dt>
                      <dd>${group.year}</dd>
                    </div>
                  </dl>
                </article>
              `).join('')}
            </div>
          `}
        </section>
      </section>
    </main>
  `
}) %>
