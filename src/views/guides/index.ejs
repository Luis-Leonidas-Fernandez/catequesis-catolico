<%
  const canUploadGuide = ['admin', 'coordinador_zonal', 'coordinador_parroquial', 'catequista_familiar', 'catequista_juvenil'].includes(user.role);
  const isAdmin = user.role === 'admin';
  const totalGuides = guides.length;
  const totalLevelsWithGuides = new Set(guides.map((item) => item.catechesis_level_name || 'Sin nivel')).size;
  const totalParishesWithGuides = new Set(guides.map((item) => item.parish_name || 'Sin parroquia')).size;
  const totalYearsWithGuides = new Set(guides.map((item) => item.year || 'Sin año')).size;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page guides-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-book-half"></i>
            Guías
          </span>
          <h1 class="dashboard-title mb-3">Guías por parroquia</h1>
          <p class="dashboard-subtitle mb-0">
            Cada parroquia ve, sube y elimina únicamente sus propias guías. El PDF queda protegido fuera de la carpeta pública.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de guías">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-file-earmark-pdf-fill"></i>
            </span>
            <span class="admin-metric-card__label">Guías disponibles</span>
            <strong class="admin-metric-card__value">${totalGuides}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-layers-fill"></i>
            </span>
            <span class="admin-metric-card__label">Niveles cubiertos</span>
            <strong class="admin-metric-card__value">${totalGuides ? totalLevelsWithGuides : 0}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-calendar3"></i>
            </span>
            <span class="admin-metric-card__label">Años cubiertos</span>
            <strong class="admin-metric-card__value">${totalGuides ? totalYearsWithGuides : 0}</strong>
          </article>
        </section>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
        </div>

        ${canUploadGuide ? `
          <section class="admin-form-card guides-upload-card" aria-labelledby="guide-upload-title">
            <div class="admin-form-card__header guides-upload-card__header">
              <span class="admin-form-card__kicker" aria-hidden="true">
                <i class="bi bi-cloud-arrow-up-fill"></i>
              </span>
              <h2 id="guide-upload-title">Subir guía anual</h2>
              <p>Subí el PDF anual directamente. Si todavía tenés el formato anterior, también se acepta ZIP con un único PDF.</p>
              <span class="badge text-bg-warning"><i class="bi bi-shield-check"></i> Validación segura</span>
            </div>

            <form class="admin-form-grid guides-upload-card__form" action="/guides?_csrf=${escapeHtml(csrfToken)}" method="post" enctype="multipart/form-data" novalidate>
              <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />

              <div class="admin-form-field guides-upload-card__parish">
                <label class="form-label" for="parishId">Parroquia</label>
                ${isAdmin ? `
                  <select class="form-select ${errors.parishId ? 'is-invalid' : ''}" id="parishId" name="parishId" required>
                    <option value="">Seleccionar parroquia</option>
                    ${parishes.map((parish) => `
                      <option value="${parish.id}" ${Number(guide.parishId) === parish.id ? 'selected' : ''}>
                        ${escapeHtml(parish.name)}
                      </option>
                    `).join('')}
                  </select>
                ` : `
                  <input type="hidden" name="parishId" value="${escapeHtml(guide.parishId)}" />
                  <div class="admin-form-static-value">
                    <i class="bi bi-building-heart" aria-hidden="true"></i>
                    ${escapeHtml(parishes[0]?.name || 'Tu parroquia')}
                  </div>
                `}
                ${errors.parishId ? `<div class="invalid-feedback d-block">${escapeHtml(errors.parishId)}</div>` : ''}
              </div>

              <div class="admin-form-field guides-upload-card__level">
                <label class="form-label" for="catechesisLevelId">Nivel de catequesis</label>
                <select class="form-select ${errors.catechesisLevelId ? 'is-invalid' : ''}" id="catechesisLevelId" name="catechesisLevelId" required>
                  <option value="">Seleccionar nivel</option>
                  ${catechesisLevels.map((level) => `
                    <option value="${level.id}" ${Number(guide.catechesisLevelId) === level.id ? 'selected' : ''}>
                      ${escapeHtml(level.name)}
                    </option>
                  `).join('')}
                </select>
                ${errors.catechesisLevelId ? `<div class="invalid-feedback">${escapeHtml(errors.catechesisLevelId)}</div>` : ''}
              </div>

              <div class="admin-form-field guides-upload-card__year">
                <label class="form-label" for="year">Año</label>
                <input class="form-control ${errors.year ? 'is-invalid' : ''}" id="year" name="year" type="number" min="2000" max="2100" value="${escapeHtml(guide.year)}" required />
                ${errors.year ? `<div class="invalid-feedback">${escapeHtml(errors.year)}</div>` : ''}
              </div>

              <div class="admin-form-field guides-upload-card__title">
                <label class="form-label" for="title">Título</label>
                <input class="form-control ${errors.title ? 'is-invalid' : ''}" id="title" name="title" value="${escapeHtml(guide.title)}" required />
                ${errors.title ? `<div class="invalid-feedback">${escapeHtml(errors.title)}</div>` : ''}
              </div>

              <div class="admin-form-field admin-form-field--full guides-upload-card__description">
                <label class="form-label" for="description">Descripción</label>
                <textarea class="form-control" id="description" name="description" rows="3">${escapeHtml(guide.description)}</textarea>
              </div>

              <div class="admin-form-field admin-form-field--full guides-upload-card__file">
                <label class="form-label" for="guideFile">PDF de la guía</label>
                <input class="form-control ${errors.guideZip ? 'is-invalid' : ''}" id="guideFile" name="guideFile" type="file" accept=".pdf,application/pdf,.zip,application/zip,application/x-zip-compressed" required />
                ${errors.guideZip ? `<div class="invalid-feedback">${escapeHtml(errors.guideZip)}</div>` : ''}
                <div class="form-text">
                  Máximo 20 MB. Recomendado: PDF directo. Compatibilidad: ZIP con un único PDF.
                </div>
              </div>

              <div class="admin-form-actions">
                <button class="btn admin-resource-primary-action" type="submit" data-loading-text="Subiendo guía...">
                  <i class="bi bi-cloud-upload-fill"></i>
                  Subir guía
                </button>
              </div>
            </form>
          </section>
        ` : ''}

        <section class="admin-table-card guides-table-card" aria-labelledby="guides-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="guides-table-title">
                <i class="bi bi-file-earmark-pdf-fill"></i>
                Guías disponibles
              </h2>
              <p>Descargá el PDF correspondiente a cada nivel de catequesis.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table guides-resource-table">
              <thead>
                <tr>
                  <th>Título</th>
                  <th>Nivel</th>
                  <th>Parroquia</th>
                  <th>Año</th>
                  <th>Creada</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${guides.length === 0 ? `
                  <tr>
                    <td class="text-center py-5" colspan="6">
                      <div class="admin-table-empty">
                        <i class="bi bi-folder-x"></i>
                        <strong>Todavía no hay guías subidas.</strong>
                        <span>Cuando se cargue una guía anual, va a aparecer en este listado.</span>
                      </div>
                    </td>
                  </tr>
                ` : guides.map((item) => `
                  <tr>
                    <td data-label="Título">
                      <div class="admin-table-user">
                        <div class="admin-table-avatar admin-table-avatar--pdf" aria-hidden="true">
                          <i class="bi bi-filetype-pdf"></i>
                        </div>
                        <div>
                          <span class="admin-table-user__name">${escapeHtml(item.title)}</span>
                          ${item.description ? `<p class="admin-table-description">${escapeHtml(item.description)}</p>` : ''}
                        </div>
                      </div>
                    </td>
                    <td data-label="Nivel"><code>${escapeHtml(item.catechesis_level_name || 'Sin nivel')}</code></td>
                    <td data-label="Parroquia">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-building-heart"></i>
                        ${escapeHtml(item.parish_name || 'Sin parroquia')}
                      </span>
                    </td>
                    <td data-label="Año">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-calendar-check"></i>
                        ${escapeHtml(item.year || 'Sin año')}
                      </span>
                    </td>
                    <td data-label="Creada">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-calendar3"></i>
                        ${escapeHtml(item.created_at)}
                      </span>
                    </td>
                    <td data-label="Acciones" class="text-end">
                      <div class="admin-table-actions">
                        <a class="btn btn-sm btn-outline-primary" href="/guides/${item.id}/download">
                          <i class="bi bi-download me-1"></i>Descargar PDF
                        </a>
                        ${canUploadGuide ? `
                          <form action="/guides/${item.id}/delete" method="post">
                            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">
                              <i class="bi bi-trash3 me-1"></i>Eliminar
                            </button>
                          </form>
                        ` : ''}
                      </div>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
