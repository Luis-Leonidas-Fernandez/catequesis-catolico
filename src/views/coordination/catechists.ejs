<%
  const totalCatechists = catechists.length;
  const activeCatechists = catechists.filter((catechist) => catechist.is_active).length;
  const groupsAssigned = catechists.reduce((sum, catechist) => sum + Number(catechist.groups_count || 0), 0);
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page coordination-page">
      <nav class="dashboard-navbar" aria-label="Navegación principal">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav"><span class="dashboard-user-icon" aria-hidden="true"><i class="bi bi-person-fill"></i></span><span class="dashboard-user-role">${escapeHtml(user.role)}</span></div>
          <form action="/logout" method="post"><input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" /><button class="btn dashboard-logout-btn" type="submit"><i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>Salir</button></form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow"><i class="bi bi-eye-fill"></i> Observación parroquial</span>
          <h1 class="dashboard-title mb-3">Catequistas de mi parroquia</h1>
          <p class="dashboard-subtitle mb-0">Vista de solo lectura de catequistas registrados en tu parroquia.</p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de catequistas">
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-person-workspace"></i></span><span class="admin-metric-card__label">Catequistas</span><strong class="admin-metric-card__value">${totalCatechists}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-person-check-fill"></i></span><span class="admin-metric-card__label">Activos</span><strong class="admin-metric-card__value">${activeCatechists}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-collection-fill"></i></span><span class="admin-metric-card__label">Grupos asignados</span><strong class="admin-metric-card__value">${groupsAssigned}</strong></article>
        </section>

        <section class="admin-table-card coordination-catechists-table-card" aria-labelledby="coordination-catechists-title">
          <div class="admin-table-card__header"><div><h2 id="coordination-catechists-title"><i class="bi bi-person-lines-fill"></i> Catequistas visibles</h2><p>Solo se listan catequistas pertenecientes a tu parroquia.</p></div></div>
          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-table coordination-catechists-table">
              <thead><tr><th>Nombre</th><th>Email</th><th>Rol</th><th>Grupos</th><th>Estado</th></tr></thead>
              <tbody>
                ${catechists.length ? catechists.map((catechist) => `
                  <tr>
                    <td data-label="Nombre"><strong class="admin-table-user__name">${escapeHtml(catechist.name)}</strong><br><small>${escapeHtml(catechist.parish_name || '')}</small></td>
                    <td data-label="Email">${escapeHtml(catechist.email)}</td>
                    <td data-label="Rol"><span class="admin-status-pill">${escapeHtml(catechist.role)}</span></td>
                    <td data-label="Grupos">${catechist.groups_count}</td>
                    <td data-label="Estado"><span class="admin-status-pill admin-status-pill--${catechist.is_active ? 'usada' : 'vencida'}">${catechist.is_active ? 'activo' : 'inactivo'}</span></td>
                  </tr>
                `).join('') : `<tr><td colspan="5" class="admin-empty-cell">No hay catequistas registrados en tu parroquia todavía.</td></tr>`}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
