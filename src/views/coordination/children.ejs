<%
  const totalChildren = children.length;
  const activeChildren = children.filter((child) => child.is_active).length;
  const groupsCount = new Set(children.map((child) => child.group_name || 'Sin grupo')).size;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page coordination-page">
      <nav class="dashboard-navbar" aria-label="Navegación principal">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav"><span class="dashboard-user-icon" aria-hidden="true"><i class="bi bi-person-fill"></i></span><span class="dashboard-user-role">${escapeHtml(user.role)}</span></div>
          <form action="/logout" method="post"><input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" /><button class="btn dashboard-logout-btn" type="submit"><i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>Salir</button></form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow"><i class="bi bi-eye-fill"></i> Observación parroquial</span>
          <h1 class="dashboard-title mb-3">Niños / Catecúmenos</h1>
          <p class="dashboard-subtitle mb-0">Vista de solo lectura de los catecúmenos registrados en tu parroquia.</p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de catecúmenos">
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-emoji-smile-fill"></i></span><span class="admin-metric-card__label">Catecúmenos</span><strong class="admin-metric-card__value">${totalChildren}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-person-check-fill"></i></span><span class="admin-metric-card__label">Activos</span><strong class="admin-metric-card__value">${activeChildren}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-collection-fill"></i></span><span class="admin-metric-card__label">Grupos con niños</span><strong class="admin-metric-card__value">${totalChildren ? groupsCount : 0}</strong></article>
        </section>

        <section class="admin-table-card coordination-children-table-card" aria-labelledby="coordination-children-title">
          <div class="admin-table-card__header"><div><h2 id="coordination-children-title"><i class="bi bi-people-fill"></i> Catecúmenos visibles</h2><p>Solo se listan niños pertenecientes a tu parroquia.</p></div></div>
          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-table coordination-children-table">
              <thead><tr><th>Nombre</th><th>Grupo</th><th>Nivel</th><th>Estado</th></tr></thead>
              <tbody>
                ${children.length ? children.map((child) => `
                  <tr>
                    <td data-label="Nombre"><div class="admin-table-user"><div class="admin-table-avatar">${escapeHtml((child.first_name || 'N').charAt(0).toUpperCase())}</div><div><span class="admin-table-user__name">${escapeHtml(child.first_name)} ${escapeHtml(child.last_name)}</span><br><small>${escapeHtml(child.parish_name)}</small></div></div></td>
                    <td data-label="Grupo">${escapeHtml(child.group_name)}</td>
                    <td data-label="Nivel"><span class="admin-status-pill">${escapeHtml(child.catechesis_level_name)}</span></td>
                    <td data-label="Estado"><span class="admin-status-pill admin-status-pill--${child.is_active ? 'usada' : 'vencida'}">${child.is_active ? 'activo' : 'inactivo'}</span></td>
                  </tr>
                `).join('') : `<tr><td colspan="4" class="admin-empty-cell">No hay catecúmenos en tu parroquia todavía.</td></tr>`}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
