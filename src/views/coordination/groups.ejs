<%
  const totalGroups = groups.length;
  const activeGroups = groups.filter((group) => group.is_active).length;
  const catechistsCount = new Set(groups.filter((group) => group.catechist_id).map((group) => group.catechist_id)).size;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page coordination-page">
      <nav class="dashboard-navbar coordination-groups-navbar" aria-label="Navegación principal">
        <div class="dashboard-navbar__inner coordination-groups-navbar__inner">
          <a class="coordination-groups-navbar__brand" href="/dashboard" aria-label="Catequesis San Pedro">
            <span class="dashboard-user-icon" aria-hidden="true"><i class="bi bi-church-fill"></i></span>
            <span>Catequesis San Pedro</span>
          </a>
          <div class="dashboard-navbar__actions coordination-groups-navbar__actions">
            <div class="dashboard-user-nav" aria-label="Usuario activo"><span class="dashboard-user-icon" aria-hidden="true"><i class="bi bi-person-fill"></i></span><span class="dashboard-user-role">${escapeHtml(user.role)}</span></div>
            <form action="/logout" method="post"><input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" /><button class="btn dashboard-logout-btn" type="submit"><i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>Salir</button></form>
          </div>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow"><i class="bi bi-eye-fill"></i> Observación parroquial</span>
          <h1 class="dashboard-title mb-3">Grupos de mi parroquia</h1>
          <p class="dashboard-subtitle mb-0">Vista de solo lectura para observar grupos, niveles y catequistas asociados a tu parroquia.</p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de grupos">
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-collection-fill"></i></span><span class="admin-metric-card__label">Grupos</span><strong class="admin-metric-card__value">${totalGroups}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-check2-circle"></i></span><span class="admin-metric-card__label">Activos</span><strong class="admin-metric-card__value">${activeGroups}</strong></article>
          <article class="admin-metric-card admin-resource-summary__card"><span class="admin-metric-card__icon"><i class="bi bi-person-workspace"></i></span><span class="admin-metric-card__label">Catequistas asignados</span><strong class="admin-metric-card__value">${catechistsCount}</strong></article>
        </section>

        <section class="admin-table-card coordination-groups-table-card" aria-labelledby="coordination-groups-title">
          <div class="admin-table-card__header"><div><h2 id="coordination-groups-title"><i class="bi bi-grid-3x3-gap-fill"></i> Grupos visibles</h2><p>Solo se listan grupos pertenecientes a tu parroquia.</p></div></div>
          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-table coordination-groups-table">
              <thead><tr><th>Grupo</th><th>Nivel</th><th>Catequista</th><th>Año</th><th>Estado</th></tr></thead>
              <tbody>
                ${groups.length ? groups.map((group) => `
                  <tr>
                    <td data-label="Grupo"><strong class="admin-table-user__name">${escapeHtml(group.name)}</strong><br><small>${escapeHtml(group.parish_name)}</small></td>
                    <td data-label="Nivel"><span class="admin-status-pill">${escapeHtml(group.catechesis_level_name)}</span></td>
                    <td data-label="Catequista">${escapeHtml(group.catechist_name || 'Sin asignar')}</td>
                    <td data-label="Año">${group.year}</td>
                    <td data-label="Estado"><span class="admin-status-pill admin-status-pill--${group.is_active ? 'usada' : 'vencida'}">${group.is_active ? 'activo' : 'inactivo'}</span></td>
                  </tr>
                `).join('') : `<tr><td colspan="5" class="admin-empty-cell">No hay grupos creados en tu parroquia todavía.</td></tr>`}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
