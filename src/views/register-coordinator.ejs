<%
  const safeForm = form || {};
  const shellClasses = ['login-shell', 'register-shell'];
  const safeLoginVideoUrl = loginVideoUrl ? escapeHtml(loginVideoUrl) : '';
  const safeLoginPosterUrl = loginPosterUrl ? escapeHtml(loginPosterUrl) : '';
  const roleLabels = {
    coordinador_parroquial: 'Coordinador parroquial',
    coordinador_zonal: 'Coordinador zonal',
  };

  if (safeLoginPosterUrl) {
    shellClasses.push('login-shell--has-poster');
  }

  const loginVideoMarkup = safeLoginVideoUrl
    ? `
      <video
        class="login-bg-video"
        aria-hidden="true"
        tabindex="-1"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        ${safeLoginPosterUrl ? `poster="${safeLoginPosterUrl}"` : ''}
      >
        <source src="${safeLoginVideoUrl}" type="video/mp4" />
      </video>
    `
    : '';
%>

<%- include('layout', {
  title,
  body: `
    <main class="${shellClasses.join(' ')} coordinator-register-shell">
      ${loginVideoMarkup}
      <div class="login-overlay" aria-hidden="true"></div>

      <section class="login-content register-content" aria-label="Registro de coordinador">
        <div class="login-card register-card">
          <div class="login-header register-header">
            <span class="badge text-bg-primary mb-3">Invitación segura</span>
            <h1 class="login-title">Registro de coordinador</h1>
            <p class="login-subtitle">
              ${invitation
                ? `Completá tu acceso como ${escapeHtml(roleLabels[invitation.role] || invitation.role)}. Vas a crear tu parroquia y solo verás información asociada a ella.`
                : 'Necesitás una invitación vigente para completar este registro.'}
            </p>
          </div>

          ${pageError ? `<div class="alert alert-danger" role="alert">${escapeHtml(pageError)}</div>` : ''}
          ${errors.email ? `<div class="alert alert-danger" role="alert">${escapeHtml(errors.email)}</div>` : ''}

          ${invitation && !pageError ? `
            <form class="login-form register-form" action="/registro-coordinador" method="post" novalidate>
              <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
              <input type="hidden" name="token" value="${escapeHtml(token)}" />

              <div class="login-field">
                <label class="form-label" for="emailView">Email invitado</label>
                <input class="form-control" id="emailView" value="${escapeHtml(invitation.email)}" disabled />
              </div>

              <div class="login-field">
                <label class="form-label" for="name">Nombre completo</label>
                <input
                  class="form-control ${errors.name ? 'is-invalid' : ''}"
                  id="name"
                  name="name"
                  value="${escapeHtml(safeForm.name || '')}"
                  autocomplete="name"
                  required
                />
                ${errors.name ? `<div class="invalid-feedback">${escapeHtml(errors.name)}</div>` : ''}
              </div>

              <div class="login-field">
                <label class="form-label" for="parishName">Nombre de tu parroquia</label>
                <input
                  class="form-control ${errors.parishName ? 'is-invalid' : ''}"
                  id="parishName"
                  name="parishName"
                  value="${escapeHtml(safeForm.parishName || '')}"
                  autocomplete="organization"
                  placeholder="Ej: San Pedro"
                  required
                />
                ${errors.parishName ? `<div class="invalid-feedback">${escapeHtml(errors.parishName)}</div>` : ''}
              </div>

              <div class="login-field">
                <label class="form-label" for="password">Contraseña</label>
                <input
                  class="form-control ${errors.password ? 'is-invalid' : ''}"
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="new-password"
                  required
                />
                ${errors.password ? `<div class="invalid-feedback">${escapeHtml(errors.password)}</div>` : ''}
              </div>

              <button class="btn btn-primary login-submit register-submit" type="submit">
                Crear acceso
              </button>
            </form>
          ` : ''}

          <p class="login-secondary-action">
            ¿Ya tenés usuario?
            <a href="/login">Volvé al login</a>
          </p>
        </div>
      </section>
    </main>
  `
}) %>
