<%- include('layout', {
  title,
  body: `
    <main class="dashboard-page min-vh-100">
      <nav class="navbar navbar-expand-lg dashboard-navbar dashboard-main-navbar" aria-label="Navegación principal">
        <div class="dashboard-navbar__inner dashboard-main-navbar__inner">
          <a class="dashboard-main-navbar__brand" href="/dashboard" aria-label="Catequesis San Pedro">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-church-fill"></i>
            </span>
            <span>Catequesis San Pedro</span>
          </a>

          <div class="dashboard-navbar__actions dashboard-main-navbar__actions">
            <div class="dashboard-user-nav" aria-label="Usuario activo">
              <span class="dashboard-user-icon" aria-hidden="true">
                <i class="bi bi-person-fill"></i>
              </span>
              <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
            </div>

            <form action="/logout" method="post">
              <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
              <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
                <i class="bi bi-box-arrow-right me-1"></i>Salir
              </button>
            </form>
          </div>
        </div>
      </nav>

      <section class="dashboard-container py-5">
        <div class="app-hero dashboard-hero text-center">
            <h1 class="dashboard-title mb-3">${escapeHtml(dashboard.heading)}</h1>
            <p class="dashboard-subtitle mb-0">${escapeHtml(dashboard.description)}</p>
        </div>

        <div class="dashboard-section">
          <div class="dashboard-section__header">
            <h2>Accesos rápidos</h2>
            <p>Elegí qué necesitás gestionar ahora.</p>
          </div>

          <div class="quick-menu dashboard-quick-menu">
            ${dashboard.links.map((link) => `
              <a class="quick-menu__link" href="${escapeHtml(link.href)}">
                <span class="quick-menu__media" aria-hidden="true">
                  <img src="${escapeHtml(dashboardCardImageUrl)}" alt="" loading="lazy" />
                </span>
                <span class="quick-menu__content">
                  <span class="quick-menu__title">${escapeHtml(link.label)}</span>
                  <small class="quick-menu__description">${escapeHtml(link.description)}</small>
                </span>
                <span class="quick-menu__footer" aria-hidden="true">
                  <span class="quick-menu__action">
                    <i class="bi bi-arrow-right"></i>
                  </span>
                </span>
              </a>
            `).join('')}
          </div>
        </div>
      </section>
    </main>
  `
}) %>
