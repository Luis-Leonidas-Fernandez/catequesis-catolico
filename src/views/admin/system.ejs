<%
  const totalAuditLogs = system.auditLogs.length;
  const totalErrorLogs = system.errorLogs.length;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page admin-system-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-cpu-fill"></i>
            Sistema
          </span>
          <h1 class="dashboard-title mb-3">Logs y auditoría</h1>
          <p class="dashboard-subtitle mb-0">
            Últimas acciones auditadas y errores técnicos recientes para soporte del sistema.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen del sistema">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-clock-history"></i>
            </span>
            <span class="admin-metric-card__label">Acciones auditadas</span>
            <strong class="admin-metric-card__value">${totalAuditLogs}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-exclamation-triangle-fill"></i>
            </span>
            <span class="admin-metric-card__label">Errores recientes</span>
            <strong class="admin-metric-card__value">${totalErrorLogs}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <a class="btn admin-resource-primary-action" href="/admin/backups">
            <i class="bi bi-cloud-arrow-down-fill"></i>
            Ver backups
          </a>
        </div>

        <section class="admin-table-card" aria-labelledby="system-audit-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="system-audit-table-title">
                <i class="bi bi-clock-history"></i>
                Últimas acciones auditadas
              </h2>
              <p>Registro de eventos relevantes realizados por usuarios o por el sistema.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table admin-system-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Usuario</th>
                  <th>Acción</th>
                  <th>Entidad</th>
                  <th>Detalle</th>
                </tr>
              </thead>
              <tbody>
                ${system.auditLogs.length === 0 ? `
                  <tr>
                    <td class="text-center py-5" colspan="5">
                      <div class="admin-table-empty">
                        <i class="bi bi-journal-x"></i>
                        <strong>No hay auditoría registrada.</strong>
                        <span>Cuando se generen acciones auditables, van a aparecer acá.</span>
                      </div>
                    </td>
                  </tr>
                ` : system.auditLogs.map((log) => `
                  <tr>
                    <td data-label="Fecha">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-calendar3"></i>
                        ${escapeHtml(log.created_at)}
                      </span>
                    </td>
                    <td data-label="Usuario">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-person-circle"></i>
                        ${escapeHtml(log.user_name || log.user_email || 'Sistema')}
                      </span>
                    </td>
                    <td data-label="Acción"><code>${escapeHtml(log.action)}</code></td>
                    <td data-label="Entidad">
                      <span class="badge text-bg-primary">
                        <i class="bi bi-box-seam"></i>
                        ${escapeHtml(log.entity_type)} ${log.entity_id ? `#${log.entity_id}` : ''}
                      </span>
                    </td>
                    <td data-label="Detalle">
                      <span class="admin-system-detail">${escapeHtml(log.metadataText || 'Sin detalle')}</span>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>

        <section class="admin-table-card" aria-labelledby="system-errors-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="system-errors-table-title">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Errores recientes
              </h2>
              <p>Últimos errores técnicos detectados en logs de aplicación.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table admin-system-table admin-system-errors-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Nivel</th>
                  <th>Ruta</th>
                  <th>Estado</th>
                  <th>Mensaje</th>
                </tr>
              </thead>
              <tbody>
                ${system.errorLogs.length === 0 ? `
                  <tr>
                    <td class="text-center py-5" colspan="5">
                      <div class="admin-table-empty admin-table-empty--success">
                        <i class="bi bi-check-circle-fill"></i>
                        <strong>No hay errores recientes.</strong>
                        <span>El registro técnico no muestra errores críticos en este momento.</span>
                      </div>
                    </td>
                  </tr>
                ` : system.errorLogs.map((log) => `
                  <tr>
                    <td data-label="Fecha">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-calendar-event"></i>
                        ${escapeHtml(log.time)}
                      </span>
                    </td>
                    <td data-label="Nivel"><span class="badge text-bg-secondary">${escapeHtml(log.level)}</span></td>
                    <td data-label="Ruta"><code class="admin-system-route">${escapeHtml(`${log.method || ''} ${log.path || ''}`.trim() || 'Sin ruta')}</code></td>
                    <td data-label="Estado"><span class="badge text-bg-danger">${escapeHtml(log.status || 'Sin estado')}</span></td>
                    <td data-label="Mensaje"><span class="admin-system-message">${escapeHtml(log.message || 'Sin mensaje')}</span></td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
