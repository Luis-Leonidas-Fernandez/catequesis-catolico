<%
  const totalUsers = users.length;
  const activeUsers = users.filter((item) => item.is_active).length;
%>

<%- include('../../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-people-fill"></i>
            Admin
          </span>
          <h1 class="dashboard-title mb-3">Usuarios administrativos</h1>
          <p class="dashboard-subtitle mb-0">
            Alta, edición y desactivación lógica de usuarios.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de usuarios">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-person-check-fill"></i>
            </span>
            <span class="admin-metric-card__label">Usuarios activos</span>
            <strong class="admin-metric-card__value">${activeUsers}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-people-fill"></i>
            </span>
            <span class="admin-metric-card__label">Total registrados</span>
            <strong class="admin-metric-card__value">${totalUsers}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <a class="btn admin-resource-primary-action" href="/admin/users/new">
            <i class="bi bi-person-plus-fill"></i>
            Crear usuario
          </a>
        </div>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
          ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-exclamation-circle-fill text-danger fs-5"></i><span>${escapeHtml(error)}</span></div>` : ''}
        </div>

        <section class="admin-table-card admin-users-table-card" aria-labelledby="admin-users-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="admin-users-table-title">Listado de usuarios</h2>
              <p>Gestioná permisos, estado y datos administrativos.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table admin-users-resource-table">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Email</th>
                  <th>Rol</th>
                  <th>Parroquia</th>
                  <th>Estado</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${users.map((item) => `
                  <tr>
                    <td data-label="Nombre">
                      <div class="admin-table-user">
                        <div class="admin-table-avatar" aria-hidden="true">
                          ${escapeHtml(item.name.charAt(0).toUpperCase())}
                        </div>
                        <span class="admin-table-user__name">${escapeHtml(item.name)}</span>
                      </div>
                    </td>
                    <td data-label="Email">${escapeHtml(item.email)}</td>
                    <td data-label="Rol"><code>${escapeHtml(item.role)}</code></td>
                    <td data-label="Parroquia">${escapeHtml(item.parish_name || 'Sin parroquia')}</td>
                    <td data-label="Estado">
                      <span class="badge ${item.is_active ? 'text-bg-success' : 'text-bg-secondary'}">
                        <i class="bi bi-circle-fill admin-status-dot"></i>
                        ${item.is_active ? 'Activo' : 'Inactivo'}
                      </span>
                    </td>
                    <td data-label="Acciones" class="text-end">
                      <div class="admin-table-actions">
                        <a class="btn btn-sm btn-outline-primary" href="/admin/users/${item.id}/edit">
                          <i class="bi bi-pencil-fill me-1"></i>Editar
                        </a>
                        ${item.is_active ? `
                          <form action="/admin/users/${item.id}/deactivate" method="post">
                            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">
                              <i class="bi bi-slash-circle me-1"></i>Desactivar
                            </button>
                          </form>
                        ` : ''}
                      </div>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
