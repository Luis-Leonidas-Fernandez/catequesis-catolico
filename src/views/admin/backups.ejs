<%
  const totalBackups = backups.length;
  const createdBackups = backups.filter((backup) => backup.status === 'created').length;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page admin-backups-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-database-fill"></i>
            Sistema
          </span>
          <h1 class="dashboard-title mb-3">Backups manuales de SQLite</h1>
          <p class="dashboard-subtitle mb-0">
            Generá una copia segura del archivo SQLite actual. Esta pantalla no restaura backups.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de backups">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-archive-fill"></i>
            </span>
            <span class="admin-metric-card__label">Backups registrados</span>
            <strong class="admin-metric-card__value">${totalBackups}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-check-circle-fill"></i>
            </span>
            <span class="admin-metric-card__label">Creados correctamente</span>
            <strong class="admin-metric-card__value">${createdBackups}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <form action="/admin/backups" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn admin-resource-primary-action" type="submit">
              <i class="bi bi-cloud-arrow-up-fill"></i>
              Crear backup
            </button>
          </form>
        </div>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
          ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-exclamation-circle-fill text-danger fs-5"></i><span>${escapeHtml(error)}</span></div>` : ''}
        </div>

        <section class="admin-table-card" aria-labelledby="admin-backups-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="admin-backups-table-title">
                <i class="bi bi-database-fill"></i>
                Backups existentes
              </h2>
              <p>Listado de copias manuales generadas desde el panel admin.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table admin-backups-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Archivo</th>
                  <th>Estado</th>
                  <th>Creado por</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${backups.length === 0 ? `
                  <tr>
                    <td class="text-center py-5" colspan="5">
                      <div class="admin-table-empty">
                        <i class="bi bi-folder-x"></i>
                        <strong>Todavía no hay backups registrados.</strong>
                        <span>Creá el primer backup manual para dejar una copia segura del SQLite actual.</span>
                      </div>
                    </td>
                  </tr>
                ` : backups.map((backup) => `
                  <tr>
                    <td data-label="Fecha">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-calendar3"></i>
                        ${escapeHtml(backup.created_at)}
                      </span>
                    </td>
                    <td data-label="Archivo">
                      <div class="admin-table-user admin-backup-file">
                        <div class="admin-table-avatar admin-table-avatar--backup" aria-hidden="true">
                          <i class="bi bi-file-earmark-binary-fill"></i>
                        </div>
                        <code>${escapeHtml(backup.file_path)}</code>
                      </div>
                    </td>
                    <td data-label="Estado">
                      <span class="badge text-bg-success">
                        <i class="bi bi-check-circle-fill admin-status-dot"></i>
                        ${escapeHtml(backup.status)}
                      </span>
                    </td>
                    <td data-label="Creado por">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-person-fill"></i>
                        ${escapeHtml(backup.created_by_name || backup.created_by_email || 'Sistema')}
                      </span>
                    </td>
                    <td data-label="Acciones" class="text-end">
                      ${backup.media_asset_id ? `
                        <a class="btn btn-sm btn-outline-primary" href="/admin/backups/${backup.id}/download">
                          <i class="bi bi-download me-1"></i>Descargar
                        </a>
                      ` : '<span class="text-muted">Legacy local</span>'}
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
