<%
  const totalActivities = activities.length;
  const activeActivities = activities.filter((activity) => activity.is_active).length;
  const totalQuestions = activities.reduce(
    (sum, activity) => sum + Number(activity.question_count || 0),
    0,
  );
%>

<%- include('../../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-controller"></i>
            Actividades
          </span>
          <h1 class="dashboard-title mb-3">Actividades catequísticas</h1>
          <p class="dashboard-subtitle mb-0">
            Gestión de actividades con preguntas, respuestas y puntaje para catequesis.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de actividades">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-play-circle-fill"></i>
            </span>
            <span class="admin-metric-card__label">Actividades activas</span>
            <strong class="admin-metric-card__value">${activeActivities}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-question-circle-fill"></i>
            </span>
            <span class="admin-metric-card__label">Preguntas cargadas</span>
            <strong class="admin-metric-card__value">${totalQuestions}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <a class="btn admin-resource-primary-action" href="/admin/activities/new">
            <i class="bi bi-plus-circle-fill"></i>
            Crear actividad
          </a>
        </div>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
          ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-exclamation-circle-fill text-danger fs-5"></i><span>${escapeHtml(error)}</span></div>` : ''}
        </div>

        <section class="admin-table-card" aria-labelledby="admin-activities-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="admin-activities-table-title">Listado de actividades</h2>
              <p>Ordená el contenido por tipo, nivel, preguntas, puntaje y estado.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table activities-resource-table">
              <thead>
                <tr>
                  <th>Título</th>
                  <th>Tipo</th>
                  <th>Nivel</th>
                  <th>Preguntas</th>
                  <th>Puntos</th>
                  <th>Estado</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${activities.length === 0 ? `
                  <tr>
                    <td class="text-center py-5" colspan="7">
                      <div class="admin-table-empty">
                        <i class="bi bi-journal-x"></i>
                        <strong>Todavía no hay actividades creadas.</strong>
                        <span>Creá la primera actividad para comenzar a trabajar con preguntas y respuestas.</span>
                      </div>
                    </td>
                  </tr>
                ` : activities.map((activity) => `
                  <tr>
                    <td data-label="Título">
                      <div class="admin-table-user">
                        <div class="admin-table-avatar" aria-hidden="true">
                          <i class="bi bi-controller"></i>
                        </div>
                        <span class="admin-table-user__name">${escapeHtml(activity.title)}</span>
                      </div>
                    </td>
                    <td data-label="Tipo"><code>${escapeHtml(activity.activity_type)}</code></td>
                    <td data-label="Nivel"><code>${escapeHtml(activity.catechesis_level_name)}</code></td>
                    <td data-label="Preguntas">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-question-circle-fill"></i>
                        ${activity.question_count}
                      </span>
                    </td>
                    <td data-label="Puntos">
                      <span class="badge text-bg-warning">
                        <i class="bi bi-star-fill"></i>
                        ${activity.points}
                      </span>
                    </td>
                    <td data-label="Estado">
                      <span class="badge ${activity.is_active ? 'text-bg-success' : 'text-bg-secondary'}">
                        <i class="bi bi-circle-fill admin-status-dot"></i>
                        ${activity.is_active ? 'Activo' : 'Inactivo'}
                      </span>
                    </td>
                    <td data-label="Acciones" class="text-end">
                      <div class="admin-table-actions">
                        <a class="btn btn-sm btn-outline-primary" href="/admin/activities/${activity.id}/edit">
                          <i class="bi bi-pencil-fill me-1"></i>Editar
                        </a>
                        ${activity.is_active ? `
                          <form action="/admin/activities/${activity.id}/deactivate" method="post">
                            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">
                              <i class="bi bi-slash-circle me-1"></i>Desactivar
                            </button>
                          </form>
                        ` : ''}
                      </div>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
