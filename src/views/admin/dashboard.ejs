<%
  const metricCards = [
    {
      label: 'Usuarios activos',
      value: counters.activeUsers ?? '—',
      icon: 'bi-people-fill'
    },
    {
      label: 'Niños activos',
      value: counters.activeChildren ?? '—',
      icon: 'bi-emoji-smile-fill'
    },
    {
      label: 'Grupos activos',
      value: counters.activeGroups ?? '—',
      icon: 'bi-collection-fill'
    },
    {
      label: 'Actividades activas',
      value: counters.activeActivities ?? '—',
      icon: 'bi-controller'
    }
  ];
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page admin-dashboard-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-dashboard-container">
        <div class="app-hero dashboard-hero admin-dashboard-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-shield-lock-fill"></i>
            Administrador
          </span>
          <h1 class="dashboard-title mb-3">Panel admin mínimo</h1>
          <p class="dashboard-subtitle mb-0">
            Acceso completo al sistema para <strong>${escapeHtml(user.name)}</strong>.
          </p>
        </div>

        <section class="admin-dashboard-metrics" aria-label="Resumen administrativo">
          ${metricCards.map((metric) => `
            <article class="admin-metric-card">
              <span class="admin-metric-card__icon" aria-hidden="true">
                <i class="bi ${escapeHtml(metric.icon)}"></i>
              </span>
              <span class="admin-metric-card__label">${escapeHtml(metric.label)}</span>
              <strong class="admin-metric-card__value">${escapeHtml(String(metric.value))}</strong>
            </article>
          `).join('')}
        </section>

        <section class="dashboard-section admin-dashboard-section" aria-labelledby="admin-quick-access-title">
          <div class="dashboard-section__header">
            <h2 id="admin-quick-access-title">Accesos administrativos</h2>
            <p>Elegí qué necesitás gestionar ahora.</p>
          </div>

          <div class="quick-menu dashboard-quick-menu admin-dashboard-quick-menu">
            ${cards.map((card) => `
              <a class="quick-menu__link" href="${escapeHtml(card.href)}">
                <span class="quick-menu__media" aria-hidden="true">
                  <img src="${escapeHtml(dashboardCardImageUrl)}" alt="" loading="lazy" />
                </span>
                <span class="quick-menu__content">
                  <span class="quick-menu__title">${escapeHtml(card.title)}</span>
                  <small class="quick-menu__description">${escapeHtml(card.description)}</small>
                </span>
                <span class="quick-menu__footer" aria-hidden="true">
                  <span class="quick-menu__action">
                    <i class="bi bi-arrow-right"></i>
                  </span>
                </span>
              </a>
            `).join('')}
          </div>
        </section>
      </section>
    </main>
  `
}) %>
