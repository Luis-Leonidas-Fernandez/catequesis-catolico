<%
  const totalChildren = children.length;
  const activeChildren = children.filter((child) => child.is_active).length;
%>

<%- include('../../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-emoji-smile-fill"></i>
            Niños
          </span>
          <h1 class="dashboard-title mb-3">Niños / Catecúmenos</h1>
          <p class="dashboard-subtitle mb-0">
            Gestión de niños con código seguro hasheado.
          </p>
        </header>

        <section class="admin-resource-summary" aria-label="Resumen de niños">
          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-person-check-fill"></i>
            </span>
            <span class="admin-metric-card__label">Niños activos</span>
            <strong class="admin-metric-card__value">${activeChildren}</strong>
          </article>

          <article class="admin-metric-card admin-resource-summary__card">
            <span class="admin-metric-card__icon" aria-hidden="true">
              <i class="bi bi-emoji-smile-fill"></i>
            </span>
            <span class="admin-metric-card__label">Total registrados</span>
            <strong class="admin-metric-card__value">${totalChildren}</strong>
          </article>
        </section>

        <div class="admin-resource-actions">
          <a class="btn admin-resource-primary-action" href="/admin/children/new">
            <i class="bi bi-person-plus-fill"></i>
            Crear niño
          </a>
        </div>

        <div class="admin-resource-feedback">
          ${message ? `<div class="alert alert-success d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-check-circle-fill text-success fs-5"></i><span>${escapeHtml(message)}</span></div>` : ''}
          ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2 border-0 rounded-4 shadow-sm" role="alert"><i class="bi bi-exclamation-circle-fill text-danger fs-5"></i><span>${escapeHtml(error)}</span></div>` : ''}
        </div>

        <section class="admin-table-card" aria-labelledby="admin-children-table-title">
          <div class="admin-table-card__header">
            <div>
              <h2 id="admin-children-table-title">Listado de niños</h2>
              <p>Gestioná grupo, nivel, parroquia y códigos seguros.</p>
            </div>
          </div>

          <div class="table-responsive admin-table-card__body">
            <table class="table align-middle mb-0 admin-resource-table">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Grupo</th>
                  <th>Nivel</th>
                  <th>Parroquia</th>
                  <th>Estado</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                ${children.map((child) => `
                  <tr>
                    <td data-label="Nombre">
                      <div class="admin-table-user">
                        <div class="admin-table-avatar" aria-hidden="true">
                          ${escapeHtml(child.first_name.charAt(0).toUpperCase())}
                        </div>
                        <span class="admin-table-user__name">${escapeHtml(child.last_name)}, ${escapeHtml(child.first_name)}</span>
                      </div>
                    </td>
                    <td data-label="Grupo">
                      <span class="admin-table-inline-icon">
                        <i class="bi bi-collection-fill"></i>
                        ${escapeHtml(child.group_name)}
                      </span>
                    </td>
                    <td data-label="Nivel"><code>${escapeHtml(child.catechesis_level_name)}</code></td>
                    <td data-label="Parroquia">${escapeHtml(child.parish_name)}</td>
                    <td data-label="Estado">
                      <span class="badge ${child.is_active ? 'text-bg-success' : 'text-bg-secondary'}">
                        <i class="bi bi-circle-fill" style="font-size: 0.45rem;"></i>
                        ${child.is_active ? 'Activo' : 'Inactivo'}
                      </span>
                    </td>
                    <td data-label="Acciones" class="text-end">
                      <div class="admin-table-actions">
                        <a class="btn btn-sm btn-outline-info" href="/perfil-nino?childId=${child.id}">
                          <i class="bi bi-eye-fill me-1"></i>Ver perfil
                        </a>
                        <a class="btn btn-sm btn-outline-primary" href="/admin/children/${child.id}/edit">
                          <i class="bi bi-pencil-fill me-1"></i>Editar
                        </a>
                        <form action="/children/${child.id}/regenerate-code" method="post">
                          <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                          <button class="btn btn-sm btn-outline-warning" type="submit">
                            <i class="bi bi-key-fill me-1"></i>Regenerar
                          </button>
                        </form>
                        ${child.is_active ? `
                          <form action="/admin/children/${child.id}/deactivate" method="post">
                            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">
                              <i class="bi bi-slash-circle me-1"></i>Desactivar
                            </button>
                          </form>
                        ` : ''}
                      </div>
                    </td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
