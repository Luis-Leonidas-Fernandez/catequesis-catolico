<%
  const isRegenerated = heading.toLowerCase().includes('regenerado');
%>

<%- include('../../layout', {
  title,
  body: `
    <main class="dashboard-page admin-resource-page child-code-page">
      <nav class="navbar navbar-expand-lg dashboard-navbar">
        <div class="dashboard-navbar__inner">
          <div class="dashboard-user-nav">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-person-fill"></i>
            </span>
            <span class="dashboard-user-role">${escapeHtml(user.role)}</span>
          </div>

          <form action="/logout" method="post">
            <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
            <button class="btn dashboard-logout-btn" type="submit" aria-label="Cerrar sesión">
              <i class="bi bi-box-arrow-right me-1"></i>Salir
            </button>
          </form>
        </div>
      </nav>

      <section class="dashboard-container admin-resource-container child-code-container">
        <header class="admin-resource-hero text-center">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-shield-lock-fill"></i>
            Código seguro
          </span>
          <h1 class="dashboard-title mb-3">${escapeHtml(heading)}</h1>
          <p class="dashboard-subtitle mb-0">${escapeHtml(description)}</p>
        </header>

        <section class="admin-form-card child-code-card" aria-labelledby="child-code-title">
          <div class="child-code-card__status" aria-hidden="true">
            <span class="admin-form-card__kicker">
              <i class="bi ${isRegenerated ? 'bi-arrow-clockwise' : 'bi-key-fill'}"></i>
            </span>
          </div>

          <div class="child-code-card__content">
            <h2 id="child-code-title">Copiá este código ahora</h2>
            <p>Este valor se muestra una sola vez. Después, en la base de datos solo queda guardado el hash.</p>

            <div class="child-code-card__code" aria-label="Código de acceso generado">
              ${escapeHtml(accessCode)}
            </div>

            <div class="child-code-card__notice" role="note">
              <i class="bi bi-info-circle-fill"></i>
              <span>No compartas este código públicamente. Entregáselo solo al niño o a su familia.</span>
            </div>

            <a class="btn admin-resource-primary-action child-code-card__action" href="${escapeHtml(backHref)}">
              <i class="bi bi-check-circle-fill"></i>
              Continuar
            </a>
          </div>
        </section>
      </section>
    </main>
  `
}) %>
