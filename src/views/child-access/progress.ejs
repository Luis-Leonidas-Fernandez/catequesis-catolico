<%
  const safeSummary = progress.summary || {};
  const firstName = safeSummary.first_name || 'amigo';
  const avatarInitial = String(firstName || '?').charAt(0).toUpperCase();
  const completed = Number(safeSummary.completed_activities || 0);
  const available = Number(safeSummary.available_activities || 0);
  const correctAnswers = Number(safeSummary.correct_answers || 0);
  const stars = Number(safeSummary.stars || 0);
  const lastPractice = safeSummary.last_access_at || 'Sin prácticas todavía';
  const completedLabel = `${completed} de ${available}`;
%>

<%- include('../layout', {
  title,
  body: `
    <main class="dashboard-page child-progress-page">
      <nav class="dashboard-navbar child-progress-navbar" aria-label="Navegación principal">
        <div class="dashboard-navbar__inner child-progress-navbar__inner">
          <a class="child-progress-navbar__brand" href="/perfil-nino" aria-label="Catequesis San Pedro">
            <span class="dashboard-user-icon" aria-hidden="true">
              <i class="bi bi-stars"></i>
            </span>
            <span>Catequesis San Pedro</span>
          </a>
          <div class="dashboard-navbar__actions child-progress-navbar__actions">
            <div class="dashboard-user-nav" aria-label="Perfil activo">
              <span class="dashboard-user-icon" aria-hidden="true">
                <i class="bi bi-person-heart"></i>
              </span>
              <span class="dashboard-user-role">niño</span>
            </div>
            <form action="/salir-nino" method="post">
              <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
              <button class="btn dashboard-logout-btn" type="submit">
                <i class="bi bi-box-arrow-right me-1" aria-hidden="true"></i>
                Salir
              </button>
            </form>
          </div>
        </div>
      </nav>

      <section class="dashboard-container child-progress-container">
        <header class="dashboard-hero child-progress-hero">
          <span class="admin-dashboard-eyebrow">
            <i class="bi bi-bar-chart-fill" aria-hidden="true"></i>
            Mi progreso
          </span>
          <h1 class="dashboard-title">¡Vamos, ${escapeHtml(firstName)}!</h1>
          <p class="dashboard-subtitle">${escapeHtml(safeSummary.motivation || 'Seguí practicando y celebrá cada avance.')}</p>
        </header>

        <section class="admin-form-card child-progress-highlight-card" aria-labelledby="child-progress-summary-title">
          <div class="child-progress-highlight-card__identity">
            <div class="child-progress-avatar" aria-hidden="true">
              ${
                safeSummary.avatar_path
                  ? `<img src="${escapeHtml(safeSummary.avatar_path)}" alt="" />`
                  : `<div class="child-progress-avatar__fallback"><i class="bi bi-person-heart"></i><span>${escapeHtml(avatarInitial)}</span></div>`
              }
            </div>
            <div>
              <span class="admin-form-card__kicker child-progress-kicker">
                <i class="bi bi-heart-pulse-fill" aria-hidden="true"></i>
                Avance general
              </span>
              <h2 id="child-progress-summary-title">Tu camino de catequesis</h2>
              <p>Un resumen claro de tus respuestas, estrellas y últimas prácticas.</p>
            </div>
          </div>

          <div class="child-progress-highlight-card__body">
            <div class="child-progress-score-ring" aria-label="Avance general ${Number(safeSummary.percentage || 0)}%">
              <span>${Number(safeSummary.percentage || 0)}%</span>
              <small>avance</small>
            </div>

            <div class="child-progress-overview">
              <div class="child-progress-bar" aria-hidden="true">
                <span class="child-progress-bar__fill ${escapeHtml(safeSummary.progressClass || 'progress-width-0')}"></span>
              </div>

              <dl class="child-progress-stats" aria-label="Resumen detallado de progreso">
                <div class="child-progress-stat child-progress-stat--stars">
                  <dt>Estrellas</dt>
                  <dd aria-label="${stars} estrellas">${'★'.repeat(stars)}${'☆'.repeat(Math.max(0, 5 - stars))}</dd>
                </div>
                <div class="child-progress-stat">
                  <dt>Completadas</dt>
                  <dd>${escapeHtml(completedLabel)}</dd>
                </div>
                <div class="child-progress-stat">
                  <dt>Correctas</dt>
                  <dd>${correctAnswers}</dd>
                </div>
                <div class="child-progress-stat child-progress-stat--wide">
                  <dt>Última práctica</dt>
                  <dd>${escapeHtml(lastPractice)}</dd>
                </div>
              </dl>
            </div>
          </div>
        </section>

        <div class="child-progress-actions">
          <a class="btn admin-resource-primary-action" href="/nino/actividades">
            <i class="bi bi-play-circle-fill me-1" aria-hidden="true"></i>
            Seguir jugando
          </a>
        </div>

        <section class="admin-table-card child-progress-completed-card" aria-labelledby="child-progress-completed-title">
          <div class="admin-table-card__header child-progress-completed-card__header">
            <span class="admin-form-card__kicker" aria-hidden="true">
              <i class="bi bi-award-fill"></i>
            </span>
            <div>
              <h2 id="child-progress-completed-title">
                <i class="bi bi-check2-circle" aria-hidden="true"></i>
                Actividades completadas
              </h2>
              <p>Todo lo que ya terminaste queda registrado acá para que veas tu camino.</p>
            </div>
          </div>

          <div class="child-progress-completed-card__body">
            ${
              progress.completedActivities.length === 0
                ? `<div class="child-progress-empty-state">
                    <span aria-hidden="true"><i class="bi bi-controller"></i></span>
                    <h3>Todavía no terminaste actividades</h3>
                    <p>Empezá con una actividad y volvé a mirar este progreso. Paso a paso, loco.</p>
                  </div>`
                : `<div class="child-progress-completed-list">
                    ${progress.completedActivities.map((activity, index) => `
                      <article class="child-progress-completed-item" style="--item-index: ${index};">
                        <span class="child-progress-completed-item__icon" aria-hidden="true">
                          <i class="bi bi-check-circle-fill"></i>
                        </span>
                        <div class="child-progress-completed-item__content">
                          <h3>${escapeHtml(activity.title)}</h3>
                          <p>
                            <i class="bi bi-card-checklist" aria-hidden="true"></i>
                            ${Number(activity.correct_answers || 0)} de ${Number(activity.total_questions || 0)} respuestas correctas
                          </p>
                        </div>
                        <div class="child-progress-completed-item__meta">
                          <span class="child-progress-score-pill">
                            <i class="bi bi-star-fill" aria-hidden="true"></i>
                            ${Number(activity.score || 0)} pts
                          </span>
                          <span class="child-progress-date-pill">
                            <i class="bi bi-clock-history" aria-hidden="true"></i>
                            ${escapeHtml(activity.completed_at || 'Sin fecha')}
                          </span>
                        </div>
                      </article>
                    `).join('')}
                  </div>`
            }
          </div>
        </section>
      </section>
    </main>
  `
}) %>
